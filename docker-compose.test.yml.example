# Template for local test stack.
# Copy to docker-compose.test.yml (gitignored) and adapt to your infra.
#
# Expects environment variables in .env (see .env.example).
# If you want Mailpit for catching test emails, add a local override:
#   docker compose -f docker-compose.test.yml -f docker-compose.test.local.yml up -d
#
# Typical infra prereqs (adapt to yours):
#   - A shared external network (e.g. "shared") with postgres reachable
#   - A host-reachable Ollama instance (set OLLAMA_URL in .env)

services:
  aingram-api-test:
    build:
      context: .
      dockerfile: Dockerfile.test
    container_name: aingram-api-test
    image: aingram-api-test
    env_file:
      - .env
    environment:
      - NODE_ENV=test
      - DB_HOST=postgres
      - AGORAI_URL=http://agorai-aingram-test:3200
      - EMBEDDING_MODEL=bge-m3
      # AGORAI_PASS_KEY, OLLAMA_URL, SMTP_* loaded from .env (gitignored).
    volumes:
      - ./src:/app/src
      - ./build:/app/build
      - ./migrations:/app/migrations
      - ./scripts:/app/scripts
      - ./tests:/app/tests
      - ./package.json:/app/package.json
      - ./tsconfig.json:/app/tsconfig.json
    networks:
      - shared
      - aingram-network
    depends_on:
      agorai-aingram-test:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:3000/health').then(r=>{if(!r.ok)throw 1})"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s

  agorai-aingram-test:
    build: /path/to/Agorai
    container_name: agorai-aingram-test
    entrypoint: ["node", "dist/cli.js", "serve", "--host", "0.0.0.0", "--no-keryx"]
    healthcheck:
      test: ["CMD", "wget", "-q", "-O-", "http://127.0.0.1:3200/health"]
      interval: 30s
      timeout: 3s
      retries: 3
    environment:
      - AGORAI_PORT=3200
      - AGORAI_DATA_HOME=/data
    volumes:
      - agorai-aingram-data:/data
      - ./agorai.config.json:/app/agorai.config.json:ro
    networks:
      - shared
      - aingram-network

  aingram-worker-test:
    build:
      context: .
      dockerfile: Dockerfile.test
    container_name: aingram-worker-test
    entrypoint: ["node", "src/workers/index.js"]
    env_file:
      - .env
    environment:
      - NODE_ENV=test
      - DB_HOST=postgres
      # OLLAMA_URL, SMTP_* loaded from .env (gitignored).
    volumes:
      - ./src:/app/src
      - ./build:/app/build
    networks:
      - shared
      - aingram-network
    depends_on:
      aingram-api-test:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "node", "-e", "fetch('http://localhost:3001/health').then(r=>{if(!r.ok)throw 1})"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s

volumes:
  agorai-aingram-data:

networks:
  shared:
    external: true
  aingram-network:
