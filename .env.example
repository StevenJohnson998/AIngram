# =============================================================================
# AIngram — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database (REQUIRED) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aingram
DB_USER=admin
DB_PASSWORD=changeme

# --- Authentication (REQUIRED) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# --- Agorai — Discussion Engine (REQUIRED for discussions) ---
# URL of the Agorai sidecar (included in docker-compose.yml)
AGORAI_URL=http://agorai:3100
# Must match the API key defined in agorai.config.json
AGORAI_PASS_KEY=changeme

# --- Ollama — Embeddings (REQUIRED for vector search) ---
# URL of the Ollama instance (included in docker-compose.yml)
OLLAMA_URL=http://ollama:11434
# Embedding model — bge-m3 is multilingual, 1024 dimensions
EMBEDDING_MODEL=bge-m3
# Timeout for embedding requests (ms)
# EMBEDDING_TIMEOUT_MS=5000

# --- GUI ---
# Public URL where the GUI is served (for CORS and email links)
# AINGRAM_GUI_ORIGIN=http://localhost:3000

# --- Branding (optional — defaults to AIngram open-source branding) ---
# BRAND_NAME=AIlore
# BRAND_HTML=<span>AI</span>lore
# BRAND_GITHUB_URL=https://github.com/StevenJohnson998/AIngram

# --- Analytics (optional — no tracking if not set) ---
# ANALYTICS_SCRIPT_URL=https://analytics.example.com/script.js
# ANALYTICS_WEBSITE_ID=your-website-id

# --- SMTP (optional — emails degrade gracefully if not set) ---
# Test: Mailpit (docker-compose.test.yml provides aingram-mailpit-test on port 1025)
# Prod: Resend or transactional email service
# SMTP_HOST=aingram-mailpit-test
# SMTP_PORT=1025
# SMTP_USER=test
# SMTP_PASSWORD=test
# SMTP_FROM=noreply@aingram.test

# --- AI Provider encryption (optional — defaults to JWT_SECRET) ---
# Separate key for encrypting stored AI provider API keys
# AI_PROVIDER_ENCRYPTION_KEY=

# --- QuarantineValidator (optional — no quarantine if not set) ---
# Sandboxed LLM that reviews suspicious chunks for prompt injection.
# Compatible with any OpenAI-format chat completions endpoint.
# Detailed multi-provider examples + setup doc updated in task #2.
# QUARANTINE_VALIDATOR_API_KEY=
# QUARANTINE_VALIDATOR_API_URL=https://api.deepseek.com/v1/chat/completions
# QUARANTINE_VALIDATOR_MODEL=deepseek-chat
# Injection score threshold for quarantine (0-1, default 0.4)
# QUARANTINE_VALIDATOR_INJECTION_THRESHOLD=0.4
# Max pending reviews in queue before backpressure (default 100)
# QUARANTINE_VALIDATOR_MAX_QUEUE_SIZE=100
# Review rate limit (per minute, default 5)
# QUARANTINE_VALIDATOR_REVIEWS_PER_MINUTE=5
# Burst allowance (default 15)
# QUARANTINE_VALIDATOR_BURST_SIZE=15
# Daily token budget (default 500000)
# QUARANTINE_VALIDATOR_DAILY_BUDGET_TOKENS=500000
# Circuit breaker: max quarantines in window before tripping (default 20)
# QUARANTINE_VALIDATOR_CB_THRESHOLD=20
# Circuit breaker window in ms (default 600000 = 10 min)
# QUARANTINE_VALIDATOR_CB_WINDOW_MS=600000
# Worker poll interval in ms (default 10000 = 10s)
# QUARANTINE_VALIDATOR_POLL_MS=10000
