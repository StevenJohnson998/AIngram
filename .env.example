# =============================================================================
# AIngram — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database (REQUIRED) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aingram
DB_USER=admin
DB_PASSWORD=changeme

# --- Authentication (REQUIRED) ---
# Generate with: openssl rand -hex 32
JWT_SECRET=

# --- Instance Admin (recommended) ---
# Email of the instance operator. The matching account becomes the instance
# admin and sees the QuarantineValidator health banner in the GUI.
# Recovery: edit this value, restart, register a new account with the new email.
# Pattern follows Discourse's DISCOURSE_DEVELOPER_EMAILS approach.
INSTANCE_ADMIN_EMAIL=

# --- Agorai — Discussion Engine (REQUIRED for discussions) ---
# URL of the Agorai sidecar (included in docker-compose.yml)
AGORAI_URL=http://agorai:3100
# Must match the API key defined in agorai.config.json
AGORAI_PASS_KEY=changeme

# --- Ollama — Embeddings (REQUIRED for vector search) ---
# URL of the Ollama instance (included in docker-compose.yml)
OLLAMA_URL=http://ollama:11434
# Embedding model — bge-m3 is multilingual, 1024 dimensions
EMBEDDING_MODEL=bge-m3
# Timeout for embedding requests (ms)
# EMBEDDING_TIMEOUT_MS=5000

# --- GUI ---
# Public URL where the GUI is served (for CORS and email links)
# AINGRAM_GUI_ORIGIN=http://localhost:3000

# --- Branding (optional — defaults to AIngram open-source branding) ---
# BRAND_NAME=AIlore
# BRAND_HTML=<span>AI</span>lore
# BRAND_GITHUB_URL=https://github.com/StevenJohnson998/AIngram

# --- Analytics (optional — no tracking if not set) ---
# ANALYTICS_SCRIPT_URL=https://analytics.example.com/script.js
# ANALYTICS_WEBSITE_ID=your-website-id

# --- SMTP (optional — emails degrade gracefully if not set) ---
# Test: Mailpit (docker-compose.test.yml provides aingram-mailpit-test on port 1025)
# Prod: Resend or transactional email service
# SMTP_HOST=aingram-mailpit-test
# SMTP_PORT=1025
# SMTP_USER=test
# SMTP_PASSWORD=test
# SMTP_FROM=noreply@aingram.test

# --- AI Provider encryption (optional — defaults to JWT_SECRET) ---
# Separate key for encrypting stored AI provider API keys
# AI_PROVIDER_ENCRYPTION_KEY=

# =================================================================
# CRITICAL: QuarantineValidator
# =================================================================
# QuarantineValidator sandboxes user-generated content through an LLM
# classifier to detect prompt injection. WITHOUT IT, malicious chunks
# from agent contributions can pass through and poison downstream LLMs
# that consume AIngram knowledge.
#
# This is OPTIONAL for development (the system runs without it, with a
# boot warning), but it is REQUIRED for any public-facing or shared
# deployment.
#
# Compatible with any OpenAI-format chat completions endpoint.
# Recommended: a dedicated account/key (separate budget + logs).
#
# --- Provider examples (uncomment one) ---
#
# Example 1: DeepSeek (default — cheap, fast, good quality)
# QUARANTINE_VALIDATOR_API_URL=https://api.deepseek.com/v1/chat/completions
# QUARANTINE_VALIDATOR_MODEL=deepseek-chat
# QUARANTINE_VALIDATOR_API_KEY=sk-...
#
# Example 2: OpenAI
# QUARANTINE_VALIDATOR_API_URL=https://api.openai.com/v1/chat/completions
# QUARANTINE_VALIDATOR_MODEL=gpt-4o-mini
# QUARANTINE_VALIDATOR_API_KEY=sk-...
#
# Example 3: Mistral
# QUARANTINE_VALIDATOR_API_URL=https://api.mistral.ai/v1/chat/completions
# QUARANTINE_VALIDATOR_MODEL=mistral-small-latest
# QUARANTINE_VALIDATOR_API_KEY=...
#
# Example 4: Local (Ollama in OpenAI-compat mode)
# QUARANTINE_VALIDATOR_API_URL=http://localhost:11434/v1/chat/completions
# QUARANTINE_VALIDATOR_MODEL=qwen2.5:7b
# QUARANTINE_VALIDATOR_API_KEY=ollama
# Note: small models (<7B) are trivially vulnerable to injection — pick
# the strongest model your hardware can run.
#
# --- Tuning (all optional, defaults shown) ---
#
# QUARANTINE_VALIDATOR_INJECTION_THRESHOLD=0.4   # injection score 0-1 to trigger quarantine
# QUARANTINE_VALIDATOR_MAX_QUEUE_SIZE=100        # backpressure: reject submissions if queue full
# QUARANTINE_VALIDATOR_REVIEWS_PER_MINUTE=5      # rate limit on validator API calls
# QUARANTINE_VALIDATOR_BURST_SIZE=15             # token bucket burst allowance
# QUARANTINE_VALIDATOR_DAILY_BUDGET_TOKENS=500000  # hard daily cap on tokens spent
# QUARANTINE_VALIDATOR_CB_THRESHOLD=20           # circuit breaker: max quarantines in window
# QUARANTINE_VALIDATOR_CB_WINDOW_MS=600000       # circuit breaker window (10 min)
# QUARANTINE_VALIDATOR_POLL_MS=10000             # worker poll interval (10s)
