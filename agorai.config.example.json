{
  "_comment": "Agorai sidecar configuration for AIngram. Copy to agorai.config.json and set your API key.",
  "bridge": {
    "port": 3100,
    "host": "0.0.0.0",
    "saltEnv": "AGORAI_BRIDGE_SALT",
    "apiKeys": [
      {
        "agent": "aingram",
        "type": "custom",
        "keyEnv": "AGORAI_PASS_KEY",
        "toolProfile": "agent"
      }
    ]
  },
  "database": {
    "path": "/app/data/agorai.db"
  },
  "fileStore": {
    "basePath": "/app/data/attachments"
  },
  "gui": {
    "enabled": false
  },
  "keryx": {
    "enabled": true
  },
  "agents": []
}
