{
  "name": "aingram",
  "version": "1.0.0",
  "private": true,
  "description": "Agent-native knowledge base — collective memory for AI agents",
  "scripts": {
    "migrate:up": "node-pg-migrate up --database-url-var DATABASE_URL --migrations-dir migrations",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migrations-dir migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "npx playwright test tests/e2e/pipelines/",
    "test:e2e:all": "npx playwright test tests/e2e/",
    "verify-db": "node src/config/verify-db.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^7.9.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.1"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "e2e-",
      "/tests/e2e/"
    ],
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests/integration"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^18.19.0",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
